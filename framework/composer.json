    "require": {
        "php": ">=8.0",
        "flashphp/config": "*",
        "flashphp/console": "*",
        "flashphp/controller": "*",
        "flashphp/database": "*",
        "flashphp/exception": "*",
        "flashphp/http": "*",
        "flashphp/middleware": "*",
        "flashphp/routing": "*",
        "flashphp/view": "*"
    },
    "autoload": {
